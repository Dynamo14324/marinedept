  <Slicers>
    <Slicer id="S1">
      <Name>Year Filter</Name>
      <Field>Year</Field>
      <Type>Dropdown</Type>
      <Position>Top-Left</Position>
      <DefaultValue>2024</DefaultValue>
    </Slicer>
    
    <Slicer id="S2">
      <Name>Fleet Type Filter</Name>
      <Field>Fleet</Field>
      <Type>Buttons</Type>
      <Position>Top-Center</Position>
      <Options>All, Tanker, Dry</Options>
    </Slicer>
    
    <Slicer id="S3">
      <Name>Auditor Filter</Name>
      <Field>Auditor</Field>
      <Type>Dropdown</Type>
      <Position>Top-Right</Position>
    </Slicer>
  </Slicers>

  <Formatting>
    <ColorScheme>
      <Primary>#005596</Primary>
      <Secondary>#58595B</Secondary>
      <Success>#28A745</Success>
      <Alert>#DC3545</Alert>
      <Neutral>#F5F5F5</Neutral>
      <Blue>#0078D4</Blue>
      <DarkBlue>#003D82</DarkBlue>
      <Cyan>#00B4D8</Cyan>
      <Orange>#FF9500</Orange>
      <Grey>#A8A8A8</Grey>
      <Red>#FF0000</Red>
    </ColorScheme>
    
    <Fonts>
      <PageTitle>Segoe UI, 24pt, Bold, #333333</PageTitle>
      <VisualTitle>Segoe UI, 14pt, Bold, #333333</VisualTitle>
      <AxisLabel>Segoe UI, 11pt, Regular, #333333</AxisLabel>
      <DataLabel>Segoe UI, 10pt, Bold, #000000</DataLabel>
      <Legend>Segoe UI, 10pt, Regular, #333333</Legend>
    </Fonts>
    
    <Theme>Corporate Blue</Theme>
    <PageSize>16:9</PageSize>
    <Margins>10px</Margins>
  </Formatting>

  <InteractiveFeatures>
    <CrossFiltering>Enabled</CrossFiltering>
    <DrillThrough>Enabled</DrillThrough>
    <Tooltips>Enabled</Tooltips>
    <Bookmarks>Enabled</Bookmarks>
    <AutoRefresh>
      <Enabled>Yes</Enabled>
      <Frequency>Daily</Frequency>
      <Time>06:00 AM</Time>
    </AutoRefresh>
  </InteractiveFeatures>

  <DAXMeasures>
    <Measure name="Total_Audits">
      <Formula>COUNTROWS(FactAudits)</Formula>
      <Description>Total number of audits conducted</Description>
    </Measure>
    
    <Measure name="Total_NCs">
      <Formula>SUM(FactAudits[NC]) + SUM(FactAudits[Observations])</Formula>
      <Description>Total non-conformities and observations</Description>
    </Measure>
    
    <Measure name="NC_per_Audit">
      <Formula>DIVIDE([Total_NCs], [Total_Audits], 0)</Formula>
      <Description>Average non-conformities per audit</Description>
    </Measure>
    
    <Measure name="Target_Achievement">
      <Formula>IF([NC_per_Audit] &lt;= 0.10, "✓ On Track", "⚠ Needs Attention")</Formula>
      <Description>Performance against KPI target</Description>
    </Measure>
  </DAXMeasures>
